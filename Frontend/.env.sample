# =========================================
# 🌍 Frontend Environment Variables
# =========================================
# Copy this file to .env and fill in your values:
#   cp .env.sample .env
#
# ⚠️  All variables MUST be prefixed with VITE_
#     to be accessible in the browser via import.meta.env
# =========================================


# =========================================
# 🌐 Backend API Base URL
# =========================================
# For local development:
VITE_API_URL=http://localhost:3001

# For production (uncomment and set your deployed backend URL):
# VITE_API_URL=https://your-backend-url.onrender.com


# =========================================
# 🔐 Google OAuth Client ID
# =========================================
# Must match the Client ID configured in Google Cloud Console.
# Add your frontend domain to "Authorized JavaScript Origins"
# in your OAuth credentials settings.
# https://console.cloud.google.com/apis/credentials
#
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
